# ============================================================================
#  CHANAKYA — AI-Powered Energy Crisis Operating System
#  FULL data-source configuration (every layer from the ideation doc).
#
#  Copy to `.env` and fill in the free keys you want. The platform degrades
#  gracefully: with ZERO keys it still runs (grounded agents + keyless GDELT &
#  Open-Meteo + realistic fallbacks). Add keys to light up more live data.
#
#  TAGS:
#   [WIRED]   = an ingestion adapter reads this today
#   [KEYLESS] = no key required, works out of the box
#   [PLANNED] = config slot ready; adapter can be added on request
#  After editing this file, RESTART the backend (settings load at startup).
# ============================================================================


# ===========================================================================
#  A. LLM PROVIDERS  — the 6-agent council (need at least ONE for live LLM)
#  Tried in PRIMARY -> fallback order. With none set, agents use grounded mode.
# ===========================================================================
LLM_PRIMARY_PROVIDER=groq            # anthropic | mistral | groq | gemini | nvidia | openrouter | deepseek

# Groq — https://console.groq.com/keys           [WIRED] free, fastest for 6 agents
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Mistral — https://console.mistral.ai/api-keys/   [WIRED] OpenAI-compatible
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
# Google Gemini — https://aistudio.google.com/app/apikey   [WIRED] free tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# NVIDIA NIM — https://build.nvidia.com           [WIRED] free tier
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# OpenRouter — https://openrouter.ai/keys         [WIRED] has free models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# DeepSeek — https://platform.deepseek.com        [WIRED] cheap / trial credits
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


# ===========================================================================
#  LAYER 1 — GEOPOLITICAL INTELLIGENCE  (the primary trigger)
# ===========================================================================
# GDELT 2.0 DOC/GEO/Timeline APIs — https://api.gdeltproject.org   [WIRED][KEYLESS]
GDELT_ENABLED=true
# NewsAPI — https://newsapi.org/register           [PLANNED] free dev tier
NEWSAPI_KEY=
# Mediastack — https://mediastack.com/             [PLANNED] free tier
MEDIASTACK_API_KEY=
# Event Registry (NewsAPI.ai) — https://eventregistry.org/  [PLANNED] free tier
EVENT_REGISTRY_API_KEY=
# ACLED armed conflict — https://acleddata.com/register/     [PLANNED] free (email+key)
ACLED_API_KEY=
ACLED_EMAIL=
# ReliefWeb humanitarian — https://reliefweb.int/help/api    [PLANNED][KEYLESS]
RELIEFWEB_ENABLED=true


# ===========================================================================
#  LAYER 2 — MARITIME INTELLIGENCE  (crude arrives by sea)
# ===========================================================================
# aisstream.io live AIS websocket — https://aisstream.io      [WIRED] free
AISSTREAM_API_KEY=
# AISHub — https://www.aishub.net/                            [PLANNED] free w/ contribution
AISHUB_USERNAME=
# MarineTraffic — https://www.marinetraffic.com/en/ais-api-services  [PLANNED] limited free
MARINETRAFFIC_API_KEY=
# Global Fishing Watch — https://globalfishingwatch.org/our-apis/    [PLANNED] free token
GFW_API_TOKEN=
# MarineCadastre / NOAA historical AIS — https://marinecadastre.gov/ais/  [PLANNED][KEYLESS] bulk


# ===========================================================================
#  LAYER 3 — ENERGY MARKET  (prices, OPEC, IEA, India PPAC)
# ===========================================================================
# Alpha Vantage Brent/WTI — https://www.alphavantage.co/support/#api-key  [WIRED] free
ALPHA_VANTAGE_API_KEY=
# EIA US energy — https://www.eia.gov/opendata/register.php   [WIRED] free
EIA_API_KEY=
# FRED (St. Louis Fed) — https://fred.stlouisfed.org/docs/api/api_key.html  [PLANNED] free
FRED_API_KEY=
# Nasdaq Data Link (Quandl) — https://data.nasdaq.com/sign-up  [PLANNED] free tier
NASDAQ_DATA_LINK_API_KEY=
# PPAC India baseline snapshot — https://www.ppac.gov.in/  [WIRED][CACHED]
PPAC_ENABLED=true


# ===========================================================================
#  LAYER 4 — WEATHER  (ports, cyclones, shipping, refineries)
# ===========================================================================
# Open-Meteo — https://open-meteo.com/             [WIRED][KEYLESS] confirmed LIVE
OPEN_METEO_ENABLED=true
# OpenWeather — https://openweathermap.org/api      [PLANNED] free tier
OPENWEATHER_API_KEY=
# NOAA / NWS — https://www.weather.gov/documentation/services-web-api  [PLANNED][KEYLESS]
NOAA_TOKEN=
# NASA POWER — https://power.larc.nasa.gov/docs/services/api/  [PLANNED][KEYLESS]
NASA_POWER_ENABLED=true
# ECMWF Open Data — https://www.ecmwf.int/en/forecasts/datasets/open-data  [PLANNED][KEYLESS]
ECMWF_ENABLED=true
# IMD (India Meteorological Dept) — https://mausam.imd.gov.in/  [PLANNED] partial open


# ===========================================================================
#  LAYER 5 — SATELLITE / EARTH OBSERVATION  (the "wow" for judges)
# ===========================================================================
# Copernicus Data Space (Sentinel-1 SAR / Sentinel-2) — https://dataspace.copernicus.eu/  [PLANNED] free
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
# Sentinel Hub — https://www.sentinel-hub.com/     [PLANNED] free trial
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
# Google Earth Engine — https://earthengine.google.com/  [PLANNED] free (service account json path)
GEE_SERVICE_ACCOUNT_JSON=
# NASA FIRMS fire/thermal — https://firms.modaps.eosdis.nasa.gov/api/  [WIRED] free MAP_KEY
NASA_FIRMS_MAP_KEY=
# NASA Earthdata (MODIS/VIIRS/Landsat) — https://urs.earthdata.nasa.gov/  [PLANNED] free
EARTHDATA_TOKEN=
# ISRO Bhuvan — https://bhuvan.nrsc.gov.in/        [PLANNED] India EO datasets


# ===========================================================================
#  LAYER 6 — GIS / DIGITAL TWIN BASEMAP
# ===========================================================================
# Map tiles: CartoDB dark is used by default and needs NO token.  [WIRED][KEYLESS]
# Mapbox (optional richer basemap) — https://account.mapbox.com/  [PLANNED] free tier
NEXT_PUBLIC_MAPBOX_TOKEN=
# OpenStreetMap / OpenSeaMap / Natural Earth — [KEYLESS] tiles & GeoJSON, no key


# ===========================================================================
#  LAYER 7 — ECONOMIC / MACRO
# ===========================================================================
# World Bank — https://data.worldbank.org/         [PLANNED][KEYLESS]
WORLD_BANK_ENABLED=true
# IMF — https://www.imf.org/en/Data                [PLANNED][KEYLESS]
IMF_ENABLED=true
# Trading Economics — https://tradingeconomics.com/api/  [PLANNED] free tier
TRADING_ECONOMICS_API_KEY=
# RBI (Reserve Bank of India) — https://www.rbi.org.in/  [PLANNED] open data


# ===========================================================================
#  LAYER 8/9 — SANCTIONS, TRADE & SUPPLY CHAIN
# ===========================================================================
# OpenSanctions / OFAC — https://www.opensanctions.org/api/  [WIRED] curated fallback w/o key
SANCTIONS_ENABLED=true
OPENSANCTIONS_API_KEY=
# UN Comtrade — https://comtradeplus.un.org/       [PLANNED] free tier
UN_COMTRADE_API_KEY=


# ===========================================================================
#  LAYER 10 — KNOWLEDGE / RAG CORPUS  (deterministic embeddings in Qdrant)
#  Curated official-source evidence manifest. [WIRED]
# ===========================================================================
RAG_CORPUS_ENABLED=true


# ===========================================================================
#  DATASTORES  (defaults match docker-compose.yml)
# ===========================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chanakya
POSTGRES_PASSWORD=chanakya_dev_pw
POSTGRES_DB=chanakya
DATABASE_URL=postgresql+asyncpg://chanakya:chanakya_dev_pw@localhost:5432/chanakya
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chanakya_dev_pw
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=


# ===========================================================================
#  APP  (CHANAKYA runs on 8010/3100 to avoid other local projects on 8000/3000)
# ===========================================================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
FRONTEND_ORIGIN=http://localhost:3100
ENVIRONMENT=development
LOG_LEVEL=INFO
PROCESS_ROLE=all
ALLOWED_ORIGINS=
OPERATOR_PIN=change-this-for-hosting
EVENT_POLL_SECONDS=300
EVENT_STREAM_NAME=chanakya:events
EVENT_DEAD_LETTER_STREAM=chanakya:events:dead
EVENT_STREAM_MAXLEN=5000
# Frontend -> backend (also set in frontend/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8010
