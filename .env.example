# CHANAKYA local development environment
#
# Copy this file to `.env` for local/Docker development. Never put real keys in
# this tracked file. Railway does not upload local ignored `.env` files: enter
# deployment values in the Railway service's Variables tab instead.

# ---- App ----
ENVIRONMENT=development
LOG_LEVEL=INFO
PROCESS_ROLE=all
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8010
FRONTEND_ORIGIN=http://localhost:3100
ALLOWED_ORIGINS=
OPERATOR_PIN=dev-local-pin
EVENT_POLL_SECONDS=300
EVENT_STREAM_NAME=chanakya:events
EVENT_DEAD_LETTER_STREAM=chanakya:events:dead
EVENT_STREAM_MAXLEN=5000

# ---- LLM router ----
# Select one configured provider as primary; configured providers are fallback.
LLM_PRIMARY_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- Live intelligence sources (optional) ----
# GDELT and Open-Meteo are keyless. Other adapters degrade safely when blank.
GDELT_ENABLED=true
OPEN_METEO_ENABLED=true
OPENWEATHER_API_KEY=
EIA_API_KEY=
ALPHA_VANTAGE_API_KEY=
AISSTREAM_API_KEY=
OPENSANCTIONS_API_KEY=
NASA_FIRMS_MAP_KEY=

# ---- Local Docker datastores ----
DATABASE_URL=postgresql+asyncpg://chanakya:chanakya_dev_pw@localhost:5435/chanakya
REDIS_URL=redis://localhost:6380/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chanakya_dev_pw
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Frontend local development only ----
# In Vercel, set these to the deployed Railway backend URL instead.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8010
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8010
