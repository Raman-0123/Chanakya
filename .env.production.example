# ============================================================================
#  CHANAKYA — Production environment matrix (example)
#
#  Copy to your host's secret store (Railway Variables, Vercel Project env, etc.)
#  and fill in real values. NEVER commit the filled-in version.
#
#  Intended layout:
#    Frontend         -> Vercel            (Next.js)
#    Backend API + WS -> Railway           (FastAPI container, always-on)
#    PostgreSQL       -> Supabase
#    Redis            -> Upstash
#    Neo4j            -> Neo4j AuraDB
#    Qdrant           -> Qdrant Cloud
#    LLM              -> any one provider below
# ============================================================================

# ---- App ----
ENVIRONMENT=production
LOG_LEVEL=INFO
PROCESS_ROLE=all
# Public origin of the deployed frontend (used for CORS).
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# ---- Security (REQUIRED for readiness) ----
# Mission activation is gated on this PIN. Must be a strong secret (>=8 chars,
# not a placeholder) or /readyz stays "degraded" in production.
OPERATOR_PIN=replace-with-a-long-random-secret

# ---- Datastores (managed) ----
# Supabase Postgres — use the asyncpg driver and the pooled connection string.
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Upstash Redis — use the rediss:// TLS URL.
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379
# Neo4j AuraDB — note the neo4j+s:// scheme (TLS).
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-aura-password
# Qdrant Cloud — cluster URL + API key.
QDRANT_URL=https://XXXXXXXX.cloud.qdrant.io:6333
QDRANT_API_KEY=replace-with-qdrant-api-key

# ---- LLM (configure one or more; the router falls back across configured providers) ----
LLM_PRIMARY_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- Live data sources (optional; each degrades gracefully if unset) ----
# Keyless live: GDELT + Open-Meteo (enabled by default).
GDELT_ENABLED=true
OPEN_METEO_ENABLED=true
# Keyed live sources — set to upgrade provenance from simulated/replay to live.
OPENWEATHER_API_KEY=
EIA_API_KEY=
ALPHA_VANTAGE_API_KEY=
AISSTREAM_API_KEY=
OPENSANCTIONS_API_KEY=
# NASA FIRMS satellite thermal layer — without this key it reports UNAVAILABLE.
NASA_FIRMS_MAP_KEY=

# ---- Frontend build-time (set in Vercel, not here) ----
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app
# NEXT_PUBLIC_WS_BASE_URL=wss://your-backend.up.railway.app
